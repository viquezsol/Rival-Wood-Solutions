    {
      "parameters": {
        "jsCode": "const mensaje = $input.first().json.mensaje || '';\nconst nombreCliente = $input.first().json.nombreCliente;\nconst tipoCliente = $input.first().json.tipoCliente;\nconst sessionId = $input.first().json.sessionId;\nconst timestamp = $input.first().json.timestamp;\n\nconst esValido = mensaje.trim().length > 0 && mensaje.length <= 2000;\n\nconst intencion = /cotiza|precio|cuanto cuesta|presupuesto/i.test(mensaje)\n  ? 'cotizacion'\n  : /pedido|orden|estado|entrega/i.test(mensaje)\n  ? 'seguimiento'\n  : /cita|visita|asesor|llamada/i.test(mensaje)\n  ? 'agendar'\n  : /queja|defecto|problema|mal/i.test(mensaje)\n  ? 'queja'\n  : 'general';\n\nreturn [{\n  json: {\n    sessionId,\n    mensaje: mensaje.trim(),\n    nombreCliente,\n    tipoCliente,\n    timestamp,\n    esValido,\n    intencion\n  }\n}];"
      },
      "id": "7f5c8ef9-a89c-4834-8968-150008a17b53",
      "name": "③ Code - Validar Mensaje",
